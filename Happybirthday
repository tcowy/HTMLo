<!DOCTYPE html>
<html>
<head>
<title>Háp pi bớt đê</title>

<style>
body {
    background-size: cover;
    background-image: url(access/nenqua.png);
}

/* hộp cha */
#box {
    position: absolute;
    left: 200px;
    top: 200px;
    cursor: pointer;
}

/* thân hộp */
#hq {
    display: block;
}

/* nắp */
#nq {
    position: absolute;
    top: -5px;
    left: 0;
    transition: 0.6s cubic-bezier(0.2, 1.5, 0.5, 1);
    transform-origin: left top;
}

/* chữ */
#text {
    position: absolute;
    top: 80px; /* chỉnh lại cho nằm trong hộp */
    left: -25px;
    width: 250px;
    text-align: center;

    font-size: 20px;
    color: black;

    opacity: 0;
    transform: translateY(20px);
    transition: 0.6s;

    z-index: 10;
}

/* phóng to */
.open {
    transform: scale(1.3);
    transition: 0.6s cubic-bezier(0.2, 1.5, 0.5, 1);
}

/* mở nắp */
.open #nq {
    transform: translateY(-120px);
}

/* hiện chữ */
.open #text {
    opacity: 1;
    transform: translateY(-65px);
}
</style>

</head>

<body>

<div id="box">

    <img src="access/hopqua.png" id="hq" width="200">
    <img src="access/napqua.png" id="nq" width="200">

    <!-- ✅ ĐẶT Ở ĐÂY -->
    <div id="text">
        🎉 <b>Happy Birthday </b> <br> <b>7/6/2026</b> 🎂
    </div>

</div>

<script>
const box = document.getElementById("box");

box.onclick = function() {
    this.classList.toggle("open");
};
</script>

</body>
</html>
